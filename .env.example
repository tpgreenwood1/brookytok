# =============================================================================
# brooky-tok Environment Variables
# =============================================================================
# Copy this file to .env and fill in values for local development.
# Never commit .env to source control.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
# Local Docker:  postgresql://postgres:password@localhost:5432/brookytok
# Neon (prod):   postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/brookytok"

# ── BetterAuth ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET="replace-this-with-a-random-32-byte-hex-string"

# Base URL of your app (no trailing slash)
# Local:      http://localhost:3000
# Production: https://your-app.vercel.app
BETTER_AUTH_URL="http://localhost:3000"

# Public base URL (safe to expose to the browser)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
# All four R2_* variables are server-only (never expose to the browser).
# Find these in the Cloudflare dashboard → R2 → Manage R2 API tokens.

# Your Cloudflare account ID (visible in the dashboard URL and R2 overview page)
R2_ACCOUNT_ID="your-cloudflare-account-id"

# R2 API token credentials (create a token with Object Read & Write permissions)
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"

# The name of the R2 bucket to store media in
R2_BUCKET_NAME="brooky-tok-media"

# Public URL for the bucket — either:
#   • A custom domain you have configured (recommended for production)
#   • The r2.dev subdomain (enable in Cloudflare dashboard → bucket → Settings → Public access)
# Example: https://media.yourdomain.com  or  https://pub-xxxx.r2.dev
# No trailing slash.
R2_PUBLIC_URL="https://pub-xxxx.r2.dev"

# ── Upload size limits ────────────────────────────────────────────────────────
# Maximum file size in MB for each media type. Defaults apply if not set.
# Must use NEXT_PUBLIC_ prefix so limits are enforced in the browser too.
NEXT_PUBLIC_MAX_IMAGE_FILE_SIZE_MB=5
NEXT_PUBLIC_MAX_VIDEO_FILE_SIZE_MB=25
